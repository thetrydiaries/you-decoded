# ── Supabase ──────────────────────────────────────────────────────────
# Project URL: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Service role key (SECRET — server only, never exposed to the browser).
# Same page, under "Project API keys" → service_role.
# Note: this app deliberately has no anon-key browser client.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Anthropic ─────────────────────────────────────────────────────────
# console.anthropic.com → API Keys. Used for all passport synthesis.
ANTHROPIC_API_KEY=sk-ant-...

# ── App ───────────────────────────────────────────────────────────────
# Used to build absolute share URLs and OG image links.
# Local: http://localhost:3000 · Prod: your Vercel domain.
NEXT_PUBLIC_APP_URL=http://localhost:3000
